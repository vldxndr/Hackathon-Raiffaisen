      "── Modele antrenate pe CSV REALIST ──\n",
      "  RIDGE       MAE=  124$  RMSE=  156$  R²=0.8726  →  models/realistic_ridge.pth\n",
      "  RF          MAE=  150$  RMSE=  187$  R²=0.8160  →  models/realistic_rf.pth\n",

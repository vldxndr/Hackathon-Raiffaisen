   "source": [
    "## 10b. Antrenare pe Date Realiste\n",
    "Generăm un CSV nou unde `Price ($)` e calculat dintr-o formulă realistă:\n",
    "- **Brand** — Apple cel mai scump, Acer cel mai ieftin\n",
    "- **Procesor** — Intel i9 > AMD Ryzen 9 > Intel i7 > AMD Ryzen 7 > AMD Ryzen 5 > Intel i5\n",
    "- **GPU** — RTX 3070 > RTX 3060 > GTX 1650 > AMD Radeon > Intel UHD\n",
    "- **RAM, Storage, Ecran, Baterie, Garanție** — contribuie proporțional la preț\n",
    "- **Zgomot gaussian** ±$150 pentru variație naturală"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 291,
   "id": "e680c532",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "CSV realist salvat: laptop_price_realistic.csv\n",
      "  Preț: min=$826  max=$3562  medie=$2074\n",
      "\n",
      "Preț mediu per Brand:\n",
      "Brand\n",
      "Apple     2618.0\n",
      "Razer     2367.0\n",
      "MSI       2197.0\n",
      "Dell      1986.0\n",
      "HP        1971.0\n",
      "Asus      1898.0\n",
      "Lenovo    1843.0\n",
      "Acer      1752.0\n"
     ]
    }
   ],
   "source": [
    "df_orig = pd.read_csv(\"laptop Price Prediction Dataset.csv\")\n",
    "\n",
    "BRAND_BASE = {\n",
    "    \"Apple\": 1500, \"Razer\": 1300, \"MSI\": 1100,\n",
    "    \"Dell\": 900,   \"HP\": 850,    \"Asus\": 800,\n",
    "    \"Lenovo\": 750, \"Acer\": 650,\n",
    "}\n",
    "PROCESSOR_PREMIUM = {\n",
    "    \"Intel i9\": 400,    \"AMD Ryzen 9\": 300,\n",
    "    \"Intel i7\": 250,    \"AMD Ryzen 7\": 200,\n",
    "    \"AMD Ryzen 5\": 100, \"Intel i5\": 50,\n",
    "}\n",
    "GPU_PREMIUM = {\n",
    "    \"NVIDIA RTX 3070\": 500, \"NVIDIA RTX 3060\": 350,\n",
    "    \"NVIDIA GTX 1650\": 150, \"AMD Radeon\": 100, \"Intel UHD\": 0,\n",
    "}\n",
    "\n",
    "np.random.seed(42)\n",
    "realistic_price = (\n",
    "    df_orig[\"Brand\"].map(BRAND_BASE)\n",
    "    + df_orig[\"Processor\"].map(PROCESSOR_PREMIUM)\n",
    "    + df_orig[\"RAM (GB)\"] * 8\n",
    "    + df_orig[\"Storage (GB)\"] * 0.15\n",
    "    + df_orig[\"Graphics Card\"].map(GPU_PREMIUM)\n",
    "    + (df_orig[\"Screen Size (inches)\"] - 13) * 20\n",
    "    - (df_orig[\"Weight (kg)\"] - 1.0) * 40\n",
    "    + df_orig[\"Battery Life (hours)\"] * 15\n",
    "    + df_orig[\"Warranty (years)\"] * 75\n",
    "    + np.random.normal(0, 150, len(df_orig))\n",
    ").clip(400, 4500).round(2)\n",
    "\n",
    "df_realistic = df_orig.copy()\n",
    "df_realistic[\"Price ($)\"] = realistic_price\n",
    "df_realistic.to_csv(\"laptop_price_realistic.csv\", index=False)\n",
    "\n",
    "print(f\"CSV realist salvat: laptop_price_realistic.csv\")\n",
    "print(f\"  Preț: min=${realistic_price.min():.0f}  max=${realistic_price.max():.0f}  medie=${realistic_price.mean():.0f}\")\n",
    "print(f\"\\nPreț mediu per Brand:\")\n",
    "print(df_realistic.groupby(\"Brand\")[\"Price ($)\"].mean().sort_values(ascending=False).round(0).to_string())"
   ]
  },

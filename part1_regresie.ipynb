   "source": [
    "# Pregătire date realiste\n",
    "df_r = df_realistic.drop(columns=[\"Model\"])\n",
    "X_r  = df_r.drop(columns=[\"Price ($)\"])\n",
    "y_r  = df_r[\"Price ($)\"]\n",
    "\n",
    "X_r_train, X_r_test, y_r_train, y_r_test = train_test_split(X_r, y_r, test_size=0.2, random_state=42)\n",
    "\n",
    "preprocessor_r = ColumnTransformer([\n",
    "    (\"num\",     StandardScaler(),                                             num_cols),\n",
    "    (\"cat_ohe\", OneHotEncoder(handle_unknown=\"ignore\", sparse_output=False),  cat_ohe),\n",
    "    (\"cat_ord\", OrdinalEncoder(categories=GPU_ORDER),                         cat_ord),\n",
    "])\n",
    "\n",
    "# Antrenare modele sklearn\n",
    "r_sklearn_models = {\n",
    "    \"ridge\": Ridge(alpha=1.0),\n",
    "    \"rf\":    RandomForestRegressor(n_estimators=200, random_state=42, n_jobs=-1),\n",
    "    \"gbr\":   GradientBoostingRegressor(n_estimators=300, learning_rate=0.05,\n",
    "                                       max_depth=5, random_state=42),\n",
    "}\n",
    "\n",
    "results_r = {}\n",
    "print(\"── Modele antrenate pe CSV REALIST ──\")\n",
    "for key, model in r_sklearn_models.items():\n",
    "    pipe = Pipeline([(\"prep\", preprocessor_r), (\"model\", model)])\n",
    "    pipe.fit(X_r_train, y_r_train)\n",
    "    y_pred = pipe.predict(X_r_test)\n",
    "\n",
    "    mae  = mean_absolute_error(y_r_test, y_pred)\n",
    "    rmse = np.sqrt(mean_squared_error(y_r_test, y_pred))\n",
    "    r2   = r2_score(y_r_test, y_pred)\n",
    "    results_r[key] = {\"MAE\": mae, \"RMSE\": rmse, \"R²\": r2}\n",
    "\n",
    "    path = f\"models/realistic_{key}.pth\"\n",
    "    joblib.dump(pipe, path)\n",
    "    print(f\"  {key.upper():<10s}  MAE={mae:5.0f}$  RMSE={rmse:5.0f}$  R²={r2:.4f}  →  {path}\")\n",
    "\n",
    "# Antrenare CatBoost\n",
    "cb_r = CatBoostRegressor(\n",
    "    iterations=500, learning_rate=0.05, depth=6,\n",
    "    loss_function=\"RMSE\", cat_features=cat_feature_names,\n",
    "    random_seed=42, verbose=0, allow_writing_files=False,\n",
    ")\n",
    "cb_r.fit(X_r_train, y_r_train, eval_set=(X_r_test, y_r_test), use_best_model=True)\n",
    "y_pred_cb = cb_r.predict(X_r_test)\n",
    "\n",
    "mae  = mean_absolute_error(y_r_test, y_pred_cb)\n",
    "rmse = np.sqrt(mean_squared_error(y_r_test, y_pred_cb))\n",
    "r2   = r2_score(y_r_test, y_pred_cb)\n",
    "results_r[\"catboost\"] = {\"MAE\": mae, \"RMSE\": rmse, \"R²\": r2}\n",
    "\n",
    "joblib.dump(cb_r, \"models/realistic_catboost.pth\")\n",
    "print(f\"  {'CATBOOST':<10s}  MAE={mae:5.0f}$  RMSE={rmse:5.0f}$  R²={r2:.4f}  →  models/realistic_catboost.pth\")\n",
    "\n",
    "joblib.dump({\"metrics\": results_r, \"target\": \"Price ($)\"}, \"models/realistic_metadata.pth\")\n",
    "print(\"\\nSalvat: models/realistic_metadata.pth\")"
   ]
